</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Pref_demo_llm_001_1">
  <rdf:type rdf:resource="#ConditionalPreference"/>
  <specifiesIntervention rdf:resource="#Interv_demo_llm_001_cpr"/>
  <sourceDocument rdf:resource="#Doc_demo_llm_001_living_will"/>
  <hasActivationCondition rdf:resource="#AC_Pref_demo_llm_001_1"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">No CPR if NYHA IV with cardiac arrest and no reversible cause</rdfs:label>
  <isNegated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isNegated>
  <hasPreferenceStrength rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Strong</hasPreferenceStrength>
  <originalText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">If I have advanced heart failure (NYHA Class IV) and my heart stops with no reversible cause, I do not want CPR.</originalText>
  <dateDocumented rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-05-27</dateDocumented>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Interv_demo_llm_001_cpr">
  <rdf:type rdf:resource="#CPR"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#AC_Pref_demo_llm_001_1">
  <rdf:type rdf:resource="#ActivationCondition"/>
  <requiresFunctionalStatus rdf:resource="#NYHA_IV_for_Pref_demo_llm_001_1"/>
  <requiresCondition rdf:resource="#Cond_demo_llm_001_advanced_heart_failure"/>
  <requiresCondition rdf:resource="#Cond_demo_llm_001_cardiac_arrest"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Activation conditions for: No CPR if NYHA IV with cardiac arrest and no reversible cause</rdfs:label>
  <hasReversibleCause rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</hasReversibleCause>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#NYHA_IV_for_Pref_demo_llm_001_1">
  <rdf:type rdf:resource="#NYHA_ClassIV"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Cond_demo_llm_001_advanced_heart_failure">
  <rdf:type rdf:resource="#AdvancedHeartFailure"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Cond_demo_llm_001_cardiac_arrest">
  <rdf:type rdf:resource="#CardiacArrest"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Pref_demo_llm_001_2">
  <rdf:type rdf:resource="#ConditionalPreference"/>
  <specifiesIntervention rdf:resource="#Interv_demo_llm_001_temporary_ventilation"/>
  <sourceDocument rdf:resource="#Doc_demo_llm_001_living_will"/>
  <hasActivationCondition rdf:resource="#AC_Pref_demo_llm_001_2"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Accept temporary ventilation if reversible cause with hope of recovery</rdfs:label>
  <isNegated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isNegated>
  <hasPreferenceStrength rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Conditional</hasPreferenceStrength>
  <originalText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">I would accept being placed on a breathing machine temporarily if there is a reversible cause and reasonable hope of recovery</originalText>
  <dateDocumented rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-05-27</dateDocumented>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Interv_demo_llm_001_temporary_ventilation">
  <rdf:type rdf:resource="#TemporaryVentilation"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#AC_Pref_demo_llm_001_2">
  <rdf:type rdf:resource="#ActivationCondition"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Activation conditions for: Accept temporary ventilation if reversible cause with hope of recovery</rdfs:label>
  <hasReversibleCause rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</hasReversibleCause>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Pref_demo_llm_001_3">
  <rdf:type rdf:resource="#ClearPreference"/>
  <specifiesIntervention rdf:resource="#Interv_demo_llm_001_indefinite_ventilation"/>
  <sourceDocument rdf:resource="#Doc_demo_llm_001_living_will"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">No indefinite ventilation</rdfs:label>
  <isNegated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isNegated>
  <hasPreferenceStrength rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Strong</hasPreferenceStrength>
  <originalText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">I do not want to be kept on a ventilator indefinitely.</originalText>
  <dateDocumented rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-05-27</dateDocumented>
